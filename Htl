periodFrom: Yup.string()
  .required("Period from is required")
  .test(
    "after-internship-end",
    "Employment start date must be after internship end date",
    function (value) {
      const rootValues = this.from?.[this.from.length - 1]?.value;
      const internshipEndDate = rootValues?.internshipEndDate;
      if (!internshipEndDate || !value) return true;
      return new Date(value) >= new Date(internshipEndDate);
    }
  ),
