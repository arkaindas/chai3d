{selectedMaster === "disciplineTypeMapping" && f.name === "discipline" ? (
  <Form.Select
    value={formData[f.name] || ""}
    onChange={(e) => handleChange(f.name, e.target.value)}
    required
  >
    <option value="">-- Select Discipline --</option>
    {disciplineMasterList.map((d) => (
      <option key={d.disciplineId} value={d.discipline}>
        {d.discipline}
      </option>
    ))}
  </Form.Select>
) : ...
