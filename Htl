internshipDetails: Yup.string()
  .max(500, "Maximum 500 characters allowed")
  .notRequired(),

internshipStartDate: Yup.string().notRequired(),

internshipEndDate: Yup.string()
  .notRequired()
  .test(
    "internship-end-after-start",
    "Internship end date cannot be before start date",
    function (value) {
      const { internshipStartDate } = this.parent;
      if (!internshipStartDate || !value) return true;

      const start = new Date(internshipStartDate);
      const end = new Date(value);

      if (isNaN(start.getTime()) || isNaN(end.getTime())) return true;

      return end >= start;
    }
  ),
