/* FMGE detection + certificate upload */
const isFMGEQual = q.qualificationName === "MBBS outside India";
let fmgeCertificateLink = null;

if (isFMGEQual && d.fmgeDetails) {
  const fmgeCert = d.fmgeDetails.certificate;
  if (fmgeCert instanceof File) {
    try {
      fmgeCertificateLink = await uploadFile(fmgeCert);
    } catch (err) {
      console.error("FMGE certificate upload failed", err);
    }
  } else if (typeof fmgeCert === "string") {
    fmgeCertificateLink = fmgeCert;
  }
}
