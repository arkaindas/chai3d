const fetchList = async () => {
  if (selectedMaster === "disciplineTypeMapping") {
    if (!formData.jobNameMasterId) {
      setList([]);
      return;
    }
    try {
      setLoading(true);
      const res = await axios.get(
        `http://13.233.124.147/api/Masters/GetDiscipline?JobNameId=${formData.jobNameMasterId}`
      );
      setList(Array.isArray(res.data) ? res.data : []);
    } catch (err) {
      console.error(err);
      setList([]);
    } finally {
      setLoading(false);
    }
    return;
  }

  if (!config?.listApi) return;

  try {
    setLoading(true);
    const res = await axios.get(config.listApi);
    setList(Array.isArray(res.data) ? res.data : []);
  } catch (err) {
    console.error(err);
    setList([]);
  } finally {
    setLoading(false);
  }
};
