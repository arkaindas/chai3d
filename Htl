const [jobDisciplineList, setJobDisciplineList] = useState([]);

const handleJobNameChange = (jobName) => {
  // existing PWBD filtering — unchanged
  if (!jobName) {
    setJobPwbdCategoryList(allPwbdCategories);
    setJobDisciplineList([]);
    return;
  }

  const filtered = allPwbdCategories.filter(
    (c) => !c.jobName || c.jobName === jobName
  );
  setJobPwbdCategoryList(filtered);

  // NEW: fetch disciplines scoped to this job
  getJobDisciplineListByJobName(jobName)
    .then((res) => setJobDisciplineList(res.data || []))
    .catch((err) => {
      console.error("Discipline fetch failed", err);
      setJobDisciplineList([]);
    });
};
