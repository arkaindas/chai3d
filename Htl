<div className="col-md-4 mb-3">
  <label>Total Score (out of 300)</label>
  <Field
    name={`education.qualifications.${actualIndex}.data.fmgeDetails.totalScore`}
  >
    {({ field, form }) => (
      <input
        {...field}
        type="text"
        className="form-control"
        onChange={(e) => {
          if (!/^\d*$/.test(e.target.value)) return; // digits only
          form.setFieldValue(field.name, e.target.value);
        }}
      />
    )}
  </Field>
</div>
