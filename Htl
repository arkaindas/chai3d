/* Add internship record, if provided */
if (values.internshipDetails || values.internshipStartDate || values.internshipEndDate) {
  const internshipPayload = {
    experienceId: uuidv4(),
    employerType: "",
    employerName: "",
    jobTitle: values.internshipDetails || "",
    durationFrom: values.internshipStartDate
      ? new Date(values.internshipStartDate).toISOString()
      : null,
    durationTo: values.internshipEndDate
      ? new Date(values.internshipEndDate).toISOString()
      : null,
    natureOfEmployment: "",
    lastCtc: 0,
    jobId: jobPostId,
    experienceCertificate: null,
    createdBy: candidateId,
    createdOn: new Date().toISOString(),
    candidateId: candidateId,
    isInternShip: true,
  };

  await addCandidateExperience(internshipPayload);
}
