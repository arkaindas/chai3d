// ─── README template ──────────────────────────────────────────────────────────
function genReadme(blockName, isContainer, parentFields, childName, childFields) {
  const title = toTitleCase(blockName);

  // Authoring table
  const buildTable = (fields, heading) => {
    const rows = fields.map((f) => {
      const multi   = f.multi ? ' *(multi)*' : '';
      const req     = f.required ? ' *(required)*' : '';
      const opts    = f.options?.length
        ? f.options.map((o) => `\`${o.value}\``).join(', ')
        : '—';
      const defVal  = f.defaultValue !== undefined ? `\`${f.defaultValue}\`` : '—';
      return `| ${f.label}${req} | \`${f.type}\`${multi} | ${f.name} | ${opts} | ${defVal} |`;
    }).join('\n');
    return `### ${heading}\n\n| Label | Type | Property | Options | Default |\n|---|---|---|---|---|\n${rows}`;
  };

  const fieldTables = isContainer
    ? `${buildTable(parentFields, 'Parent block fields (config)')}\n\n${buildTable(childFields, `Child item fields (${toTitleCase(childName)})`)}`
    : buildTable(parentFields, 'Fields');

  // Authoring structure diagram
  const authoringDiagram = isContainer
    ? `\`\`\`
| ${title}        |
|:----------------|
| (config fields) |

Then one row per ${toTitleCase(childName)}:

| ${childFields.map((f) => f.label).join(' | ')} |
|${childFields.map(() => ':---').join('|')}|
| value           |
\`\`\``
    : `\`\`\`
| ${title}   |
|:-----------|
${parentFields.map((f) => `| ${f.label} |`).join('\n')}
\`\`\``;

  return `# ${title} Block

${isContainer ? `Container block — holds repeating **${toTitleCase(childName)}** child items.` : 'Simple block with fixed authored rows.'}

---

## Authoring (document-based)

Create a table in Google Doc or SharePoint:

${authoringDiagram}

---

## Universal Editor fields

${fieldTables}

---

## Variants

Add variant names inside parentheses in the block name, e.g. **${title} (dark)**.

| Variant | CSS class |
|---|---|
| dark | \`.${blockName}--dark\` |

---

## Local development

\`\`\`bash
aem up
# open http://localhost:3000
\`\`\`

## Files

\`\`\`
blocks/${blockName}/
  ${blockName}.js     ← decoration logic
  ${blockName}.css    ← styles
  README.md           ← this file
\`\`\`
