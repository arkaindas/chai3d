// ─── Field schema builder ─────────────────────────────────────────────────────
function buildFieldSchema(fields) {
  const OPTION_TYPES = new Set(['select', 'multiselect', 'radio-group', 'checkbox-group']);
  return fields.map((f) => {
    const base = { component: f.type, name: f.name, label: f.label };
    if (f.type !== 'tab')    base.valueType   = FIELD_TYPES[f.type]?.valueType || 'string';
    if (f.required)          base.required    = true;
    if (f.readOnly)          base.readOnly    = true;
    if (f.hidden)            base.hidden      = true;
    if (f.description)       base.description = f.description;
    if (f.multi)             base.multi       = true;
    else if (f.type === 'reference') base.multi = false;

    // Real options from collector (or placeholder fallback)
    if (OPTION_TYPES.has(f.type)) {
      base.options = f.options?.length
        ? f.options
        : [{ name: 'Option 1', value: 'option-1' }, { name: 'Option 2', value: 'option-2' }];
    }

    // Default value
    if (f.defaultValue !== undefined && f.defaultValue !== '') {
      base.value = f.type === 'number'  ? Number(f.defaultValue)
                 : f.type === 'boolean' ? (f.defaultValue === 'true' || f.defaultValue === true)
                 : f.defaultValue;
    }

    if (f.type === 'date-time') { base.displayFormat = 'YYYY-MM-DD'; base.valueFormat = 'YYYY-MM-DD'; }
    if (f.type === 'aem-content-fragment') base.variationName = '';

    const validation = {};
    if (f.minLength !== undefined) validation.minLength = f.minLength;
    if (f.maxLength !== undefined) validation.maxLength = f.maxLength;
    if (f.min       !== undefined) validation.min       = f.min;
    if (f.max       !== undefined) validation.max       = f.max;
    if (f.step      !== undefined) validation.step      = f.step;
    if (f.rootPath)                validation.rootPath  = f.rootPath;
    if (f.customErrorMsg)          validation.customErrorMsg = f.customErrorMsg;
    if (Object.keys(validation).length) base.validation = validation;

    if (f.type === 'container') {
      base.collapsible = true;
      base.fields = f.subFields?.length ? buildFieldSchema(f.subFields) : [];
    }
    return base;
  });
}

// ─── Smarter decorate body — per-field code snippets ─────────────────────────
function fieldToCode(f, cellVar, indent = '  ') {
  const varName = f.name;
  switch (f.type) {
    case 'text':
    case 'textarea':
      return f.multi
        ? `${indent}const ${varName} = [...${cellVar}.querySelectorAll('p, li')].map((el) => el.textContent.trim());`
        : `${indent}const ${varName} = ${cellVar}.textContent.trim();`;
    case 'richtext':
      return `${indent}const ${varName} = ${cellVar}.innerHTML;`;
    case 'reference':
      return f.multi
        ? `${indent}const ${varName} = [...${cellVar}.querySelectorAll('picture')];`
        : `${indent}const ${varName}El = ${cellVar}.querySelector('picture');\n${indent}// createOptimizedPicture(${cellVar}.querySelector('img')?.src, '', false, [{ width: '750' }])`;
    case 'aem-content':
      return f.multi
        ? `${indent}const ${varName} = [...${cellVar}.querySelectorAll('a')].map((a) => ({ href: a.href, text: a.textContent.trim() }));`
        : `${indent}const ${varName}Link = ${cellVar}.querySelector('a');\n${indent}const ${varName}Href = ${varName}Link?.href || '';\n${indent}const ${varName}Text = ${varName}Link?.textContent.trim() || '';`;
    case 'boolean':
      return `${indent}const ${varName} = ${cellVar}.textContent.trim().toLowerCase() === 'true';`;
    case 'number':
      return `${indent}const ${varName} = parseFloat(${cellVar}.textContent.trim()) || 0;`;
    case 'select':
    case 'radio-group':
      return `${indent}const ${varName} = ${cellVar}.textContent.trim();`;
    case 'multiselect':
    case 'checkbox-group':
      return `${indent}const ${varName} = ${cellVar}.textContent.trim().split(',').map((s) => s.trim()).filter(Boolean);`;
    case 'date-time':
      return `${indent}const ${varName}Raw = ${cellVar}.textContent.trim();\n${indent}const ${varName} = ${varName}Raw ? new Date(${varName}Raw) : null;`;
    case 'aem-tag':
      return `${indent}const ${varName} = ${cellVar}.textContent.trim().split(',').map((t) => t.trim()).filter(Boolean);`;
    case 'aem-content-fragment':
    case 'aem-experience-fragment':
      return `${indent}const ${varName}Ref = ${cellVar}.querySelector('a')?.href || '';`;
    case 'container':
      if (f.subFields?.length) {
        const subCells = f.subFields.map((sf, si) =>
          `${indent}  // sub-cell[${si}]: ${sf.name} (${sf.type})\n` +
          fieldToCode(sf, `subCells[${si}]`, indent + '  ')
        ).join('\n');
        return `${indent}const ${varName}Cells = [...${cellVar}.children];\n${subCells}`;
      }
      return `${indent}const ${varName}Cells = [...${cellVar}.children];`;
    default:
      return `${indent}const ${varName} = ${cellVar}.textContent.trim();`;
  }
}

// ─── JS template — simple block ───────────────────────────────────────────────
function genSimpleBlockJS(blockName, fields) {
  const title     = toTitleCase(blockName);
  const hasMedia  = fields.some((f) => f.type === 'reference');
  const mediaImp  = hasMedia ? `import { createOptimizedPicture } from '../../scripts/aem.js';\n\n` : '';

  // Generate per-row read code
  const rowReads = fields.map((f, i) => {
    const lines = [
      `  // ── row[${i}]: ${f.label} (${f.type}${f.multi ? ', multi' : ''}) ─────────`,
      `  const cell${i} = rows[${i}]?.children[0];`,
      `  if (cell${i}) {`,
      fieldToCode(f, `cell${i}`, '    '),
      `    // TODO: use ${f.name} here`,
      `  }`,
    ];
    return lines.join('\n');
  }).join('\n\n');

  const mediaOpt = hasMedia ? `
  // Optimise all images
  block.querySelectorAll('img').forEach((img) => {
    const pic = createOptimizedPicture(img.src, img.alt, false, [{ width: '750' }]);
    img.closest('picture')?.replaceWith(pic);
  });
` : '';

  return `${mediaImp}/**
 * ${title} Block
 *
 * @param {HTMLElement} block
 */
export default function decorate(block) {
  const rows = [...block.children];
${mediaOpt}
${rowReads}

  block.classList.add('${blockName}--loaded');
}
`;
}

// ─── JS template — container block ───────────────────────────────────────────
function genContainerBlockJS(blockName, childName, parentFields, childFields) {
  const title     = toTitleCase(blockName);
  const childTitle = toTitleCase(childName);
  const hasMedia  = childFields.some((f) => f.type === 'reference');
  const mediaImp  = hasMedia ? `import { createOptimizedPicture } from '../../scripts/aem.js';\n\n` : '';

  // Parent config reads
  const configReads = parentFields.map((f, i) => {
    return [
      `  // config[${i}]: ${f.label} (${f.type})`,
      `  const cfg${i} = configCells[${i}];`,
      `  if (cfg${i}) {`,
      fieldToCode(f, `cfg${i}`, '    '),
      `    // TODO: use ${f.name}`,
      `  }`,
    ].join('\n');
  }).join('\n\n');

  // Child item reads
  const itemReads = childFields.map((f, i) => {
    return [
      `    // cell[${i}]: ${f.label} (${f.type}${f.multi ? ', multi' : ''})`,
      fieldToCode(f, `cells[${i}]`, '    '),
      `    // TODO: use ${f.name}`,
    ].join('\n');
  }).join('\n\n');

  const mediaOpt = hasMedia ? `
    // Optimise images
    item.querySelectorAll('img').forEach((img) => {
      const pic = createOptimizedPicture(img.src, img.alt, false, [{ width: '750' }]);
      img.closest('picture')?.replaceWith(pic);
    });
` : '';

  return `${mediaImp}/**
 * ${title} Block — container block
 * Each child row is a ${childTitle}.
 *
 * @param {HTMLElement} block
 */
export default function decorate(block) {
  const [configRow, ...itemRows] = [...block.children];

  // ── Parent config ────────────────────────────────────────────────
  const configCells = [...(configRow?.children || [])];

${configReads}

  // ── Child items (${childTitle}) ──────────────────────────────────
  itemRows.forEach((item, index) => {
    item.classList.add('${blockName}__item');
    item.dataset.index = index;
    const cells = [...item.children];
${mediaOpt}
${itemReads}

    // TODO: build and append your item UI here
  });

  block.classList.add('${blockName}--loaded');
}
`;
}

